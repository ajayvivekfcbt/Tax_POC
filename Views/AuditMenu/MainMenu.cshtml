@model Tx9501.Models.ViewModels.AuditMainMenuViewModel
@{
    ViewData["Title"] = "Audit Main Menu";
}

<div class="terminal-panel">
    <div class="terminal-header">
        <span class="terminal-title">TX9511 - IRS Reporting - Audit Menu</span>
        <span class="terminal-right">Year: @Model.TaxYear</span>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.StatusMessage as string))
    {
        <div class="terminal-message">@ViewBag.StatusMessage</div>
    }
    @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="terminal-error">@errorMessage</div>
    }
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="terminal-error"></div>
    }

    <div class="terminal-instructions">Select a form and press Enter.</div>

    <form asp-controller="AuditMenu" asp-action="MainMenu" method="post">
        @Html.AntiForgeryToken()
        <div class="terminal-menu-header font-monospace mt-1 mb-1">
            <span class="terminal-menu-opt-heading">Opt</span>
            <span class="terminal-menu-desc-heading">Description</span>
        </div>
        <div class="form-options">
            @foreach (var opt in Model.FormOptions)
            {
                <div class="terminal-row terminal-menu-row">
                    <span class="terminal-menu-opt-cell">
                        <input type="radio" class="terminal-opt-radio" name="SelectedForm" value="@opt.FormCode"
                               @(Model.SelectedForm == opt.FormCode ? "checked" : "") />
                    </span>
                    <label class="terminal-menu-desc font-monospace mb-0" style="cursor:pointer;">
                        @opt.Description
                    </label>
                </div>
            }
        </div>

        <div class="terminal-footer">
            <button type="submit" class="btn-terminal">Enter=Select</button>
            <button type="submit" name="ExitPressed" value="true" class="btn-terminal btn-exit">F3=Exit</button>
        </div>
    </form>
</div>
