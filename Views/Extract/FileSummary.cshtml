@model Tx9501.Models.ViewModels.ExtractFileSummaryViewModel
@{
    ViewData["Title"] = "IRS Extract Summary";
}

<div class="terminal-panel">
    <div class="terminal-header">
        <span class="terminal-title">TX9560 - IRS Extract Form Summary</span>
        <span class="terminal-right">Year: @Model.TaxYear</span>
    </div>

    <div class="terminal-row">
        <span class="terminal-label">Run Sequence</span>
        <span class="terminal-value">@Model.ExtSeq</span>
    </div>
    <div class="terminal-row">
        <span class="terminal-label">Run Description</span>
        <span class="terminal-value">@(string.IsNullOrWhiteSpace(Model.RunDescription) ? "(none)" : Model.RunDescription)</span>
    </div>
    <div class="terminal-row">
        <span class="terminal-label">Run Date</span>
        <span class="terminal-value">@(string.IsNullOrWhiteSpace(Model.RunDate) ? "(none)" : Model.RunDate)</span>
    </div>
    <div class="terminal-row">
        <span class="terminal-label">File Name</span>
        <span class="terminal-value">@(string.IsNullOrWhiteSpace(Model.FileName) ? "(not generated)" : Model.FileName)</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="terminal-message">@Model.ErrorMessage</div>
    }
    else if (Model.Summaries.Count == 0)
    {
        <div class="terminal-message">No form-level records were found in this extract file.</div>
    }
    else
    {
        <div class="table-responsive-nowrap" style="max-height: 60vh; overflow: auto;">
            <table class="terminal-table">
                <thead>
                    <tr>
                        <th style="width: 120px;">Form</th>
                        <th style="width: 110px;">A Records</th>
                        <th style="width: 110px;">B Records</th>
                        <th style="width: 110px;">C Records</th>
                        <th style="width: 120px;">Total</th>
                        <th style="width: 160px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Summaries)
                {
                    <tr>
                        <td>@row.FormType</td>
                        <td>@row.ARecords</td>
                        <td>@row.BRecords</td>
                        <td>@row.CRecords</td>
                        <td>@row.TotalRecords</td>
                        <td>
                            <a class="btn-terminal" asp-controller="Extract" asp-action="FileViewer" asp-route-year="@Model.TaxYear" asp-route-seq="@Model.ExtSeq" asp-route-form="@row.FormType">Display Full Extract</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    <div class="terminal-footer">
        <a asp-controller="Extract" asp-action="Index" class="btn-terminal btn-exit">F12=Back</a>
    </div>
</div>
