@model Tx9501.Models.ViewModels.ExtractDefineViewModel
@{
    ViewData["Title"] = Model.IsReadOnly ? "Display Extract" : "Define Extract";
}

<div class="terminal-panel">
    <div class="terminal-header">
        <span class="terminal-title">TX9560 - @ViewData["Title"]</span>
        <span class="terminal-right">Year: @Model.TaxYear</span>
    </div>

    @if (TempData["StatusMessage"] is string statusMessage && !string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="terminal-message">@statusMessage</div>
    }
    @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="terminal-error">@errorMessage</div>
    }
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="terminal-error"></div>
    }

    <form asp-controller="Extract" asp-action="Define" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="TaxYear" />
        <input type="hidden" asp-for="ExtSeq" />

        @if (Model.ExtSeq.HasValue)
        {
            <div class="terminal-row">
                <span class="terminal-label">Sequence</span>
                <span class="terminal-value">@Model.ExtSeq</span>
            </div>
        }

        <div class="terminal-row">
            <label class="terminal-label">Description</label>
            @if (Model.IsReadOnly)
            {
                <input asp-for="Description" class="terminal-input input-lg" maxlength="40" readonly />
            }
            else
            {
                <input asp-for="Description" class="terminal-input input-lg" maxlength="40" autofocus />
            }
            <span asp-validation-for="Description" class="terminal-error"></span>
        </div>
        <div class="terminal-row">
            <label class="terminal-label">Select Date</label>
            @if (Model.IsReadOnly)
            {
                <input asp-for="SelectDate" class="terminal-input input-sm" type="date" readonly />
            }
            else
            {
                <input asp-for="SelectDate" class="terminal-input input-sm" type="date" />
            }
        </div>
        <div class="terminal-row">
            <label class="terminal-label">Transmitter</label>
            @if (Model.IsReadOnly)
            {
                <input asp-for="XmtrName" class="terminal-input input-md" maxlength="40" readonly />
            }
            else
            {
                <input asp-for="XmtrName" class="terminal-input input-md" maxlength="40" />
            }
        </div>
        <div class="terminal-row">
            <label class="terminal-label">Transmitter 2</label>
            @if (Model.IsReadOnly)
            {
                <input asp-for="XmtrName2" class="terminal-input input-md" maxlength="40" readonly />
            }
            else
            {
                <input asp-for="XmtrName2" class="terminal-input input-md" maxlength="40" />
            }
        </div>

        <!-- Form Filter Section -->
        <div class="terminal-section">
            <div class="terminal-label-bold">Select Forms (leave blank for all)</div>
            @if (Model.FormOptions?.Length > 0)
            {
                <div class="terminal-checkbox-group">
                    @foreach (var form in Model.FormOptions)
                    {
                        <div class="terminal-row">
                            <input type="checkbox" id="form_@form" name="SelectedForms" value="@form" 
                                   @(Model.SelectedForms?.Contains(form) == true ? "checked" : "") 
                                   @(Model.IsReadOnly ? "disabled" : "") />
                            <label for="form_@form" class="terminal-label-inline">@form</label>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Association Filter Section -->
        <div class="terminal-section">
            <div class="terminal-label-bold">Select Associations (leave blank for all)</div>
            @if (Model.AssocOptions?.Count > 0)
            {
                <div class="terminal-checkbox-group">
                    @foreach (var assoc in Model.AssocOptions)
                    {
                        <div class="terminal-row">
                            <input type="checkbox" id="assoc_@assoc" name="SelectedAssocs" value="@assoc" 
                                   @(Model.SelectedAssocs?.Contains(assoc) == true ? "checked" : "") 
                                   @(Model.IsReadOnly ? "disabled" : "") />
                            <label for="assoc_@assoc" class="terminal-label-inline">@assoc</label>
                        </div>
                    }
                </div>
            }
            @if (Model.AssocOptions?.Count == 0)
            {
                <div class="terminal-message">No associations available for this year</div>
            }
        </div>

        <div class="terminal-footer">
            @if (!Model.IsReadOnly)
            {
                <button type="submit" class="btn-terminal">Enter=Save</button>
            }
            <button type="submit" name="CancelPressed" value="true" class="btn-terminal btn-exit">F12=Cancel</button>
        </div>
    </form>
</div>
