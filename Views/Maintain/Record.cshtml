@model Tx9501.Models.ViewModels.MaintainRecordViewModel
@using Tx9501.Models.Entities
@{
    ViewData["Title"] = Model.Mode == "ADD" ? "Add Tax Record" : "Change Tax Record";
    var r = Model.Record;
    bool is1098 = Model.FormName.StartsWith("1098", StringComparison.OrdinalIgnoreCase);
    bool isMisc = Model.FormName is "1099-MISC" or "1099-NEC";
}

<style>
    .terminal-mandatory::after {
        content: " *";
        color: #ff0000;
        font-weight: bold;
    }

    .client-invalid {
        border-color: #dc2626 !important;
        box-shadow: 0 0 0 1px rgba(220, 38, 38, 0.4);
    }
</style>

<div class="terminal-panel">
    <div class="terminal-header">
        <span class="terminal-title">
            TX9525 - @(Model.Mode == "ADD" ? "Add" : "Change") @Model.FormName Record
        </span>
        <span class="terminal-right">Year: @r.TaxYear</span>
    </div>

    <form id="maintain-record-form" asp-controller="Maintain" asp-action="Record" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Mode" />
        <input type="hidden" asp-for="FormName" />
        <input type="hidden" asp-for="Record.TaxYear" />
        <input type="hidden" asp-for="Record.Form" />
        <input type="hidden" asp-for="Record.Asa" />
        <input type="hidden" asp-for="Record.MbrNo" />
        <input type="hidden" asp-for="Record.MbrSub" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <!-- ─── Key fields (display only) ──────────────────────────── -->
        <div class="terminal-section">
            <div class="terminal-row">
                <span class="terminal-label">Assoc</span><span class="terminal-value">@r.Asa</span>
                <span class="terminal-label ms-4">Member</span><span class="terminal-value">@r.MbrNo.ToString("0") @r.MbrSub</span>
            </div>
        </div>

        <!-- ─── Customer Info Window (CUSTWDW) ────────────────────── -->
        @if (!string.IsNullOrEmpty(Model.CustomerIdNum))
        {
            <div class="terminal-section" style="border: 2px solid #0084FF; padding: 8px; background-color: #f0f8ff;">
                <div style="font-size: 0.9em;">
                    <div class="terminal-row">
                        <span class="terminal-label" style="min-width: 120px;">Taxpayer ID:</span>
                        <span class="terminal-value">@Model.CustomerIdCode @Model.CustomerIdNum</span>
                    </div>
                    <div class="terminal-row">
                        <span class="terminal-label" style="min-width: 120px;">Name:</span>
                        <span class="terminal-value">@Model.CustomerName1</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CustomerName2))
                    {
                        <div class="terminal-row">
                            <span class="terminal-label" style="min-width: 120px;"></span>
                            <span class="terminal-value">@Model.CustomerName2</span>
                        </div>
                    }
                    <div class="terminal-row">
                        <span class="terminal-label" style="min-width: 120px;">Address:</span>
                        <span class="terminal-value">@Model.CustomerName3</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CustomerName4))
                    {
                        <div class="terminal-row">
                            <span class="terminal-label" style="min-width: 120px;"></span>
                            <span class="terminal-value">@Model.CustomerName4</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ─── Borrower name / address ─────────────────────────────── -->
        <div class="terminal-section">
            <div class="terminal-row">
                <label class="terminal-label terminal-mandatory">SSN/EIN</label>
                <input asp-for="Record.SsiDn" class="terminal-input input-ssn" type="number" step="1" min="0" />
                <span asp-validation-for="Record.SsiDn" class="text-danger ms-2"></span>
                <label class="terminal-label ms-3 terminal-mandatory">Type</label>
                <input asp-for="Record.SsiDc" class="terminal-input input-xs" maxlength="1" />
                <span asp-validation-for="Record.SsiDc" class="text-danger ms-2"></span>
            </div>
            <div class="terminal-row">
                <label class="terminal-label terminal-mandatory">Name</label>
                <input asp-for="Record.BorrName" class="terminal-input input-lg" maxlength="35" />
                <span asp-validation-for="Record.BorrName" class="text-danger ms-2"></span>
            </div>
            <div class="terminal-row">
                <label class="terminal-label terminal-mandatory">Address</label>
                <input asp-for="Record.BorrAddr"  class="terminal-input input-lg" maxlength="30" />
                <span asp-validation-for="Record.BorrAddr" class="text-danger ms-2"></span>
                <input asp-for="Record.BorrAddrX" class="terminal-input input-md ms-2" maxlength="30" placeholder="Addr Line 2" />
            </div>
            <div class="terminal-row">
                <label class="terminal-label terminal-mandatory">City</label>
                <input asp-for="Record.BorrCity"  class="terminal-input input-md" maxlength="25" />
                <span asp-validation-for="Record.BorrCity" class="text-danger ms-2"></span>
                <label class="terminal-label ms-2 terminal-mandatory">St</label>
                <input asp-for="Record.BorrState" class="terminal-input input-xs" maxlength="2" />
                <span asp-validation-for="Record.BorrState" class="text-danger ms-2"></span>
                <label class="terminal-label ms-2 terminal-mandatory">Zip</label>
                <input asp-for="Record.BorrZip"   class="terminal-input input-zip" type="number" step="1" min="0" />
                <span asp-validation-for="Record.BorrZip" class="text-danger ms-2"></span>
            </div>
        </div>

        <!-- ─── IRS flags ────────────────────────────────────────────── -->
        <div class="terminal-section">
            <div class="terminal-row">
                <label class="terminal-label terminal-mandatory">Report to IRS</label>
                <select asp-for="Record.ReportToIrs" class="terminal-input input-xs">
                    <option value="">-- Select --</option>
                    <option value="Y">Y</option>
                    <option value="N">N</option>
                </select>
                <span asp-validation-for="Record.ReportToIrs" class="text-danger ms-2"></span>
                <label class="terminal-label ms-3">Corrected</label>
                <select asp-for="Record.CorrIn" class="terminal-input input-xs">
                    <option value="">No</option>
                    <option value="X">X</option>
                </select>
            </div>
            <div class="terminal-row">
                <label class="terminal-label terminal-mandatory">Non-Report Reason</label>
                <input asp-for="Record.NonRptReason" class="terminal-input input-lg" maxlength="40" placeholder="Required if Report to IRS = N" />
                <span asp-validation-for="Record.NonRptReason" class="text-danger ms-2"></span>
            </div>
        </div>

        <!-- ─── Form-specific amounts ────────────────────────────────── -->
        @if (is1098)
        {
            <div class="terminal-section">
                <div class="terminal-row">
                    <label class="terminal-label">Interest Paid</label>
                    <input asp-for="Record.IntPd"   class="terminal-input input-amt" type="number" step="0.01" />
                    <label class="terminal-label ms-3">Points</label>
                    <input asp-for="Record.Points"  class="terminal-input input-amt" type="number" step="0.01" />
                </div>
                <div class="terminal-row">
                    <label class="terminal-label">Interest (N)</label>
                    <input asp-for="Record.InterN"  class="terminal-input input-amt" type="number" step="0.01" />
                    <label class="terminal-label ms-3">Wth Held</label>
                    <input asp-for="Record.ErnWth"  class="terminal-input input-amt" type="number" step="0.01" />
                </div>
                <div class="terminal-row">
                    <label class="terminal-label">Unpaid Prin.</label>
                    <input asp-for="Record.UnpPrn"  class="terminal-input input-amt" type="number" step="0.01" />
                    <label class="terminal-label ms-3">Prop Val</label>
                    <input asp-for="Record.FmVal"   class="terminal-input input-amt" type="number" step="0.01" />
                </div>
                <!-- 1098 security/property fields -->
                <div class="terminal-row">
                    <label class="terminal-label">Orig Date</label>
                    <input asp-for="Record.OrigDate" class="terminal-input input-sm" maxlength="8" />
                    <label class="terminal-label ms-3">Acq Date</label>
                    <input asp-for="Record.MtgAcqDt" class="terminal-input input-sm" maxlength="8" />
                </div>
                <div class="terminal-row">
                    <label class="terminal-label">Sec Same</label>
                    <input asp-for="Record.SecSame"  class="terminal-input input-xs" maxlength="1" />
                    <label class="terminal-label ms-3">Sec Addr</label>
                    <input asp-for="Record.SecAddr"  class="terminal-input input-md" maxlength="40" />
                </div>
                <div class="terminal-row">
                    <label class="terminal-label">Sec Desc</label>
                    <input asp-for="Record.SecDesc"  class="terminal-input input-md" maxlength="40" />
                    <label class="terminal-label ms-3">Sec Num</label>
                    <input asp-for="Record.SecNum"   class="terminal-input input-sm" type="number" step="1" min="0" />
                </div>
            </div>
        }

        @if (isMisc)
        {
            <div class="terminal-section">
                <div class="terminal-row">
                    <label class="terminal-label">Compensation</label>
                    <input asp-for="Record.Compen"  class="terminal-input input-amt" type="number" step="0.01" />
                    <label class="terminal-label ms-3">Rents</label>
                    <input asp-for="Record.Rents"   class="terminal-input input-amt" type="number" step="0.01" />
                </div>
                <div class="terminal-row">
                    <label class="terminal-label">Med Payments</label>
                    <input asp-for="Record.MedPay"  class="terminal-input input-amt" type="number" step="0.01" />
                    <label class="terminal-label ms-3">Legal Pay</label>
                    <input asp-for="Record.LglPay"  class="terminal-input input-amt" type="number" step="0.01" />
                </div>
                <div class="terminal-row">
                    <label class="terminal-label">Other</label>
                    <input asp-for="Record.Other"   class="terminal-input input-amt" type="number" step="0.01" />
                    <label class="terminal-label ms-3">Wth Held</label>
                    <input asp-for="Record.WthHeld" class="terminal-input input-amt" type="number" step="0.01" />
                </div>
            </div>
        }

        @if (Model.FormName == "1099-A")
        {
            <div class="terminal-section">
                <div class="terminal-row">
                    <label class="terminal-label">Acq/Aband Dt</label>
                    <input asp-for="Record.DteAqr"  class="terminal-input input-sm" maxlength="8" />
                    <label class="terminal-label ms-3">FMV</label>
                    <input asp-for="Record.FmVal"   class="terminal-input input-amt" type="number" step="0.01" />
                </div>
                <div class="terminal-row">
                    <label class="terminal-label">Prop Desc</label>
                    <input asp-for="Record.PrDesc"  class="terminal-input input-lg" maxlength="40" />
                </div>
                <div class="terminal-row">
                    <label class="terminal-label">Foreign</label>
                    <input asp-for="Record.Foreign" class="terminal-input input-xs" maxlength="1" />
                    <label class="terminal-label ms-3">Unpaid Bal</label>
                    <input asp-for="Record.UnpPrn"  class="terminal-input input-amt" type="number" step="0.01" />
                </div>
            </div>
        }

        <div class="terminal-footer">
            <button type="submit" class="btn-terminal">Enter=Save</button>
            @if (Model.Mode != "ADD")
            {
                <button type="submit" name="DeletePressed" value="true" class="btn-terminal btn-danger">F14=Delete</button>
            }
            <button type="submit" name="ExitPressed" value="true" class="btn-terminal btn-exit">F12=Cancel</button>
        </div>
    </form>
</div>

@section Scripts {
<script>
(function () {
    var form = document.getElementById('maintain-record-form');
    if (!form) return;

    var lastSubmitter = null;
    form.querySelectorAll('button[type="submit"]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            lastSubmitter = btn;
        });
    });

    function isBlank(value) {
        return !value || value.trim() === '';
    }

    function readValue(selector) {
        var el = form.querySelector(selector);
        return el ? el.value : '';
    }

    function clearFieldErrors() {
        form.querySelectorAll('.client-invalid').forEach(function (el) {
            el.classList.remove('client-invalid');
        });

        form.querySelectorAll('[data-valmsg-for]').forEach(function (msg) {
            if (msg.textContent && msg.textContent.trim().length > 0) {
                msg.textContent = '';
            }
        });
    }

    function addFieldError(fieldSelector, modelFieldName, message) {
        var input = form.querySelector(fieldSelector);
        if (input) {
            input.classList.add('client-invalid');
        }

        var span = form.querySelector('[data-valmsg-for="' + modelFieldName + '"]');
        if (span) {
            span.textContent = message;
        }
    }

    form.addEventListener('submit', function (e) {
        var submitter = e.submitter || lastSubmitter;
        if (!submitter) {
            return;
        }

        if (submitter.name === 'ExitPressed' || submitter.name === 'DeletePressed') {
            return;
        }

        clearFieldErrors();
        var errors = [];

        var ssiDn = readValue('[name="Record.SsiDn"]');
        var ssiDc = readValue('[name="Record.SsiDc"]');
        var borrName = readValue('[name="Record.BorrName"]');
        var borrAddr = readValue('[name="Record.BorrAddr"]');
        var borrCity = readValue('[name="Record.BorrCity"]');
        var borrState = readValue('[name="Record.BorrState"]');
        var borrZip = readValue('[name="Record.BorrZip"]');
        var reportToIrs = readValue('[name="Record.ReportToIrs"]');
        var nonRptReason = readValue('[name="Record.NonRptReason"]');

        if (isBlank(ssiDn) || Number(ssiDn) <= 0) {
            errors.push('SSN/EIN is required.');
            addFieldError('[name="Record.SsiDn"]', 'Record.SsiDn', 'SSN/EIN is required.');
        }

        if (isBlank(ssiDc)) {
            errors.push('Type is required.');
            addFieldError('[name="Record.SsiDc"]', 'Record.SsiDc', 'Type is required.');
        }

        if (isBlank(borrName)) {
            errors.push('Name is required.');
            addFieldError('[name="Record.BorrName"]', 'Record.BorrName', 'Name is required.');
        }

        if (isBlank(borrAddr)) {
            errors.push('Address is required.');
            addFieldError('[name="Record.BorrAddr"]', 'Record.BorrAddr', 'Address is required.');
        }

        if (isBlank(borrCity)) {
            errors.push('City is required.');
            addFieldError('[name="Record.BorrCity"]', 'Record.BorrCity', 'City is required.');
        }

        if (isBlank(borrState)) {
            errors.push('State is required.');
            addFieldError('[name="Record.BorrState"]', 'Record.BorrState', 'State is required.');
        }

        if (isBlank(borrZip) || Number(borrZip) <= 0) {
            errors.push('Zip is required.');
            addFieldError('[name="Record.BorrZip"]', 'Record.BorrZip', 'Zip is required.');
        }

        if (isBlank(reportToIrs)) {
            errors.push('Report to IRS is required.');
            addFieldError('[name="Record.ReportToIrs"]', 'Record.ReportToIrs', 'Report to IRS is required.');
        }

        if (String(reportToIrs).toUpperCase() === 'N' && isBlank(nonRptReason)) {
            errors.push('Non-Report Reason is required when Report to IRS is N.');
            addFieldError('[name="Record.NonRptReason"]', 'Record.NonRptReason', 'Non-Report Reason is required when Report to IRS is N.');
        }

        if (errors.length > 0) {
            var summary = form.querySelector('[data-valmsg-summary="true"] ul');
            if (summary) {
                summary.innerHTML = '';
                errors.forEach(function (msg) {
                    var li = document.createElement('li');
                    li.textContent = msg;
                    summary.appendChild(li);
                });
                var summaryContainer = form.querySelector('[data-valmsg-summary="true"]');
                if (summaryContainer) {
                    summaryContainer.classList.remove('validation-summary-valid');
                    summaryContainer.classList.add('validation-summary-errors');
                }
            }

            e.preventDefault();
        }
    });
})();
</script>
}
