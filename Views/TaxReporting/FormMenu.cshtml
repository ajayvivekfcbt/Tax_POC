@model FormMenuViewModel
@{
    ViewData["Title"] = $"Form Menu – {Model.FormName}";
}

<!-- ═══════════════════════════════════════════════════════════════════════
     SF02 – Tax Reporting System Single Form Menu
     Mirrors TX9501FM record format SF02 and the logic in tx9501cl.clp.
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="terminal-panel">

    <!-- ── Row 1 / Row 2 header ─────────────────────────────────────────── -->
    <div class="terminal-header d-flex justify-content-between">
        <span>@DateTime.Now.ToString("MM/dd/yy")</span>
        <span class="fw-bold fs-6">Tax Reporting System - Single Form Menu</span>
        <span>TX9501</span>
    </div>
    <div class="terminal-header d-flex justify-content-between">
        <span>@DateTime.Now.ToString("HH:mm:ss")</span>
        <span class="text-info">
            @Model.FormName &nbsp;-&nbsp; @Model.FormDescription
        </span>
        <span>SF02</span>
    </div>

    <!-- ── Row 4 – Tax Year / Status ────────────────────────────────────── -->
    <div class="terminal-banner d-flex justify-content-between mt-2">
        <span>
            <span class="terminal-label">Tax Year:</span>
            <span class="terminal-value text-warning">@Model.TaxControl.TaxYear</span>
            &nbsp;
            <span class="terminal-value">@Model.TaxControl.TaxDescription</span>
        </span>
        <span>
            <span class="terminal-label">Status:</span>
            <span class="terminal-value text-warning">@Model.TaxControl.TaxStatus</span>
        </span>
    </div>

    <hr class="terminal-rule" />

    <!-- Single message area -->
    <div id="messageHost">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger py-3 px-4 font-monospace form-menu-message" role="alert" style="font-size: 0.95rem; border-left: 6px solid #dc3545; margin-bottom: 1rem; font-weight: 500;">
            <span style="font-size: 1.2rem; margin-right: 8px;">⚠️</span>
            <strong>ERROR:</strong> @Model.ErrorMessage
        </div>
    }
    else if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success py-3 px-4 font-monospace form-menu-message" role="alert" style="font-size: 0.95rem; border-left: 6px solid #28a745; margin-bottom: 1rem; font-weight: 500;">
            <span style="font-size: 1.2rem; margin-right: 8px;">✓</span>
            <strong>SUCCESS:</strong> @Model.StatusMessage
        </div>
    }
    else if (Model.IsBuildDisabled && !string.IsNullOrWhiteSpace(Model.BuildDisabledReason))
    {
        <div class="alert alert-warning py-3 px-4 font-monospace form-menu-message" role="alert" style="font-size: 0.95rem; border-left: 6px solid #ffc107; margin-bottom: 1rem; font-weight: 500;">
            <span style="font-size: 1.2rem; margin-right: 8px;">ℹ️</span>
            @Model.BuildDisabledReason
        </div>
    }
    </div>

    <hr class="terminal-rule" />

    <form asp-action="FormMenu" method="post" id="formMenuForm">
        @Html.AntiForgeryToken()

        <div class="terminal-menu-header font-monospace">
            <span class="terminal-menu-opt-heading">Opt</span>
            <span class="terminal-menu-desc-heading">Description</span>
        </div>

        <!-- ── Row 7  – Maintain ────────────────────────────────────────── -->
        @FormRow("MAINTAIN", "opt_maintain", Model.D_Maintain)

        <!-- ── Row 9  – Edit / Validate (Check for Errors) ─────────────────────────────────── -->
        @FormRow("EDIT",     "opt_edit",     "Check for Errors – select associations")

        <!-- ── Row 11 – Print Detail ────────────────────────────────────── -->
        @FormRow("PRTDTL",   "opt_prtdtl",  Model.D_PrtDtl)

        <!-- ── Row 12 – Print Exclusion ─────────────────────────────────── -->
        @FormRow("PRTEXC",   "opt_prtexc",  Model.D_PrtExc)

        <!-- ── Row 13 – Print Errors ────────────────────────────────────── -->
        @FormRow("PRTERR",   "opt_prterr",  Model.D_PrtErr)

        <!-- ── Row 14 – Summary ─────────────────────────────────────────── -->
        @FormRow("SUMMARY",  "opt_summary", Model.D_Summary)

        <!-- ── Row 15 – Admin Count Check ──────────────────────────────── -->
        @FormRow("ADMINCOUNT",  "opt_admincount", Model.D_AdminCountCheck)

        <!-- ── Row 16 – Clear ───────────────────────────────────────────── -->
        @FormRow("CLEAR",    "opt_clear",   Model.D_Clear)

        <!-- ── Row 17 – Build ───────────────────────────────────────────── -->
        @FormRow("BUILD",    "opt_build",   Model.D_Build, Model.IsBuildDisabled)

        @* Row 19 – Letter option (IN81): only shown for 1098 form *@
        @if (Model.ShowLetterOption)
        {
            @FormRow("LETTER", "opt_letter", Model.D_Letter)
        }

        <hr class="terminal-rule" />

        <!-- ── Row 24 – Function keys ────────────────────────────────────── -->
        <div class="d-flex gap-3 mt-2" id="menuButtons">
            <button type="submit" class="btn btn-success btn-sm font-monospace menuButton"
                    onclick="return validateAction();" id="enterBtn">
                Enter
            </button>
            <!-- F12 = Cancel → back to Main Menu -->
            <button type="submit" name="backToMain" value="1"
                    class="btn btn-outline-warning btn-sm font-monospace menuButton" id="cancelBtn">
                F12 = Cancel
            </button>
            <!-- F3 = Exit → clears session -->
            <button type="submit"
                    formaction="@Url.Action("Exit", "TaxReporting")"
                    formmethod="post"
                    class="btn btn-outline-secondary btn-sm font-monospace menuButton" id="exitBtn">
                F3 = Exit
            </button>
        </div>

        <!-- Validation Progress Indicator (hidden until validation runs) -->
        <div id="validationProgress" style="display: none; margin-top: 20px; padding: 20px; background-color: #f8f9fa; border-radius: 5px;">
            <div style="text-align: center; margin-bottom: 15px;">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                    <span class="visually-hidden">Validating...</span>
                </div>
            </div>
            <p class="mt-2 font-monospace text-muted" style="text-align: center; margin-bottom: 15px;">
                <strong>⏳ Validation in progress...</strong><br>
                <small>Please wait while records are being validated.</small>
            </p>
            
            <!-- Progress Bar -->
            <div style="margin-top: 15px;">
                <div class="progress" style="height: 25px;">
                    <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" 
                         role="progressbar" 
                         style="width: 0%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: white; font-size: 12px;">
                        0%
                    </div>
                </div>
                <p class="mt-2 font-monospace text-muted" style="text-align: center; margin: 0; font-size: 0.9rem;">
                    <span id="progressText">Processing records...</span>
                </p>
            </div>
        </div>

        <!-- Build Progress Indicator (hidden until build runs) -->
        <div id="buildProgress" style="display: none; margin-top: 20px; padding: 20px; background-color: #f8f9fa; border-radius: 5px;">
            <div style="text-align: center; margin-bottom: 15px;">
                <div class="spinner-border text-success" role="status" style="width: 3rem; height: 3rem;">
                    <span class="visually-hidden">Building...</span>
                </div>
            </div>
            <p class="mt-2 font-monospace text-muted" style="text-align: center; margin-bottom: 15px;">
                <strong>⏳ Build in progress...</strong><br>
                <small>Please wait while tax records are being built.</small>
            </p>
            <p class="mt-1 font-monospace text-muted" style="text-align: center; margin-bottom: 12px; font-size: 0.85rem;">
                <strong>Selected Associations:</strong>
                <span id="buildAssociationScopeText">@Model.SelectedAssociationsDisplay</span>
            </p>

            <div style="margin-top: 15px;">
                <div class="progress" style="height: 25px;">
                    <div id="buildProgressBar" class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                         role="progressbar"
                         style="width: 0%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: white; font-size: 12px;">
                        0%
                    </div>
                </div>
                <p class="mt-2 font-monospace text-muted" style="text-align: center; margin: 0; font-size: 0.9rem;">
                    <span id="buildProgressText">Building records...</span>
                </p>
                <p class="mt-1 font-monospace text-muted" style="text-align: center; margin: 0; font-size: 0.8rem;">
                    <span id="buildLastUpdateText">Last status update: waiting...</span>
                </p>
            </div>
        </div>
    </form>
</div>

@* Helper – renders one option row (radio + description), matching IBM i input-capable fields *@
@functions {
    Microsoft.AspNetCore.Html.IHtmlContent FormRow(string actionValue, string radioId, string description, bool disabled = false)
    {
        var disabledAttr = disabled ? "disabled" : string.Empty;
        var disabledClass = disabled ? " text-muted" : string.Empty;

        return new Microsoft.AspNetCore.Html.HtmlString($@"
        <div class=""terminal-row terminal-menu-row"">
            <span class=""terminal-menu-opt-cell"">
                <input type=""radio""
                       class=""form-check-input terminal-opt-radio menuRadio""
                       name=""action""
                       value=""{actionValue}""
                       id=""{radioId}""
                       {disabledAttr} />
            </span>
            <label for=""{radioId}"" class=""terminal-menu-desc font-monospace mb-0{disabledClass}"" style=""cursor:{(disabled ? "not-allowed" : "pointer")};"">
                {description}
            </label>
        </div>");
    }
}

@section Scripts {
<script>
// Track validation polling state
let validationPollingInterval = null;
let isValidationRunning = @(Model.IsValidationRunning.ToString().ToLower());
let buildPollingInterval = null;
let isBuildRunning = @(Model.IsBuildRunning.ToString().ToLower());
let initialBuildProgress = @Model.BuildProgress;
const buildInProgressStorageKey = 'taxpoc.build.inProgress';
const hasBuildStartStatus = @((Model.StatusMessage?.Contains("Build started", StringComparison.OrdinalIgnoreCase) ?? false).ToString().ToLower());
const buildPollIntervalMs = 1000;
const buildStaleThresholdSeconds = 15;
let lastBuildProgressValue = -1;
let buildUnchangedPollCount = 0;
let buildPollFailureCount = 0;
const buildPollFailureThreshold = 8;

document.addEventListener('DOMContentLoaded', function() {
    console.log('FormMenu page loaded. isBuildRunning=', isBuildRunning, 'isValidationRunning=', isValidationRunning);
    const hasBuildMarker = window.localStorage && localStorage.getItem(buildInProgressStorageKey) === '1';
    
    // If validation was already running when page loaded, start polling
    if (isValidationRunning) {
        console.log('Starting VALIDATION polling on page load');
        disableMenuOptions();
        showValidationProgress();
        startValidationPolling();
    }

    if (isBuildRunning || hasBuildStartStatus) {
        console.log('Starting BUILD polling on page load');
        isBuildRunning = true;
        disableMenuOptions();
        showBuildProgress();
        const startupProgress = Math.max(1, Math.min(Math.max(initialBuildProgress || 0, 0), 100));
        updateBuildProgress(startupProgress, 'Initializing build... waiting for first status update');
        startBuildPolling();
    } else if (hasBuildMarker) {
        // Recover from redirect/session race without showing stale progress UI.
        console.log('Found BUILD marker; probing status before showing progress UI');
        showBuildProgress();
        updateBuildProgress(1, 'Initializing build... waiting for first status update');
        disableMenuOptions();
        startBuildPolling();
    }

    // Always do a one-time status probe to recover from redirect/session race conditions.
    checkBuildStatus();
});

function validateAction() {
    const selected = document.querySelector('input[name="action"]:checked');
    if (!selected) {
        alert('Please select an option.');
        return false;
    }
    
    console.log('Form action selected:', selected.value);
    
    // For BUILD, redirect to AssociationSelect instead of submitting the form directly
    if (selected.value === 'BUILD') {
        console.log('BUILD action detected - redirecting to AssociationSelect for association selection');
        disableMenuOptions();
        // Navigate to AssociationSelect controller
        // The controller will handle the BuildSelectionPending/Confirmed flow
        window.location.href = '@Url.Action("Index", "AssociationSelect", new { returnAction = "BuildAction", returnController = "TaxReporting" })';
        return false;  // Don't submit the form
    }
    
    console.log('Form option selected:', selected.value);
    return true;
}

function disableMenuOptions() {
    // Disable all menu radio buttons
    document.querySelectorAll('.menuRadio').forEach(radio => {
        radio.disabled = true;
    });
    
    // Disable all menu buttons
    document.querySelectorAll('.menuButton').forEach(btn => {
        btn.disabled = true;
        btn.style.opacity = '0.5';
        btn.style.cursor = 'not-allowed';
    });
}

function enableMenuOptions() {
    // Enable all menu radio buttons
    document.querySelectorAll('.menuRadio').forEach(radio => {
        radio.disabled = false;
    });
    
    // Enable all menu buttons
    document.querySelectorAll('.menuButton').forEach(btn => {
        btn.disabled = false;
        btn.style.opacity = '1';
        btn.style.cursor = 'pointer';
    });
}

function showValidationProgress() {
    const progressDiv = document.getElementById('validationProgress');
    if (progressDiv) {
        progressDiv.style.display = 'block';
    }
}

function showBuildProgress() {
    const progressDiv = document.getElementById('buildProgress');
    if (progressDiv) {
        progressDiv.style.display = 'block';
    }
}

function hideBuildProgress() {
    const progressDiv = document.getElementById('buildProgress');
    if (progressDiv) {
        progressDiv.style.display = 'none';
    }
}

function updateBuildProgress(progressValue, textOverride) {
    const progress = Math.min(Math.max(progressValue || 0, 0), 100);
    const progressBar = document.getElementById('buildProgressBar');
    const progressText = document.getElementById('buildProgressText');

    if (progressBar) {
        progressBar.style.width = progress + '%';
        progressBar.textContent = progress + '%';
    }

    if (progressText) {
        progressText.textContent = textOverride || `Building records: ${progress}% complete`;
    }
}

function formatLocalTime(value) {
    if (!value) {
        return new Date().toLocaleTimeString();
    }

    const parsed = new Date(value);
    if (Number.isNaN(parsed.getTime())) {
        return new Date().toLocaleTimeString();
    }

    return parsed.toLocaleTimeString();
}

function setBuildLastUpdateText(prefix, timeValue) {
    const label = document.getElementById('buildLastUpdateText');
    if (!label) {
        return;
    }

    label.textContent = `${prefix}: ${formatLocalTime(timeValue)}`;
}

function setBuildAssociationScope(scopeDisplay) {
    const label = document.getElementById('buildAssociationScopeText');
    if (!label) {
        return;
    }

    if (scopeDisplay && String(scopeDisplay).trim().length > 0) {
        label.textContent = scopeDisplay;
    }
}

function hideValidationProgress() {
    const progressDiv = document.getElementById('validationProgress');
    if (progressDiv) {
        progressDiv.style.display = 'none';
    }
}

function startValidationPolling() {
    // Poll status every 1 second
    validationPollingInterval = setInterval(checkValidationStatus, 1000);
}

function stopValidationPolling() {
    if (validationPollingInterval) {
        clearInterval(validationPollingInterval);
        validationPollingInterval = null;
    }
}

function startBuildPolling() {
    if (buildPollingInterval) {
        return;
    }

    console.log('Starting BUILD status polling...');
    setBuildLastUpdateText('Last status update', new Date());
    buildPollingInterval = setInterval(checkBuildStatus, buildPollIntervalMs);
    checkBuildStatus();
}

function stopBuildPolling() {
    console.log('Stopping BUILD status polling...');
    if (buildPollingInterval) {
        clearInterval(buildPollingInterval);
        buildPollingInterval = null;
    }
}

function showBuildStoppedAlert(message) {
    renderFormMessage('warning', `Build stopped: ${message}`);
}

function renderFormMessage(kind, message) {
    const host = document.getElementById('messageHost');
    if (!host) {
        return;
    }

    const config = {
        success: { className: 'alert-success', border: '#28a745', prefix: 'SUCCESS:' },
        error: { className: 'alert-danger', border: '#dc3545', prefix: 'ERROR:' },
        warning: { className: 'alert-warning', border: '#ffc107', prefix: '' }
    };

    const selected = config[kind] || config.success;
    host.innerHTML = '';

    const alert = document.createElement('div');
    alert.className = `alert ${selected.className} alert-dismissible fade show py-3 px-4 font-monospace form-menu-message`;
    alert.setAttribute('role', 'alert');
    alert.style.fontSize = '0.95rem';
    alert.style.borderLeft = `6px solid ${selected.border}`;
    alert.style.marginBottom = '1rem';
    alert.style.fontWeight = '500';
    alert.innerHTML = `${selected.prefix ? `<strong>${selected.prefix}</strong> ` : ''}${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
    host.appendChild(alert);
}

function checkValidationStatus() {
    fetch('@Url.Action("GetValidationStatus", "TaxReporting")', {
        method: 'GET',
        headers: {
            'Accept': 'application/json'
        }
    })
    .then(response => response.json())
    .then(data => {
        console.log('Validation status:', data);
        
        // Update progress bar if validation is running
        if (data.isRunning) {
            const progressBar = document.getElementById('progressBar');
            const progressText = document.getElementById('progressText');
            
            if (progressBar) {
                const progress = Math.min(Math.max(data.progress || 0, 0), 100);
                progressBar.style.width = progress + '%';
                progressBar.textContent = progress + '%';
            }
            
            if (progressText) {
                const progress = data.progress || 0;
                progressText.textContent = `Processing records: ${progress}% complete`;
            }
        } else {
            // Validation has completed
            stopValidationPolling();
            hideValidationProgress();
            if (!isBuildRunning) {
                enableMenuOptions();
            }
            
            // Set progress to 100% before hiding
            const progressBar = document.getElementById('progressBar');
            if (progressBar) {
                progressBar.style.width = '100%';
                progressBar.textContent = '100%';
            }
            
            // Show completion message
            if (data.result) {
                renderFormMessage('success', data.result);
            } else if (data.error) {
                renderFormMessage('error', data.error);
            }
            
            isValidationRunning = false;
        }
    })
    .catch(error => {
        console.error('Error checking validation status:', error);
        // Continue polling on error
    });
}

function checkBuildStatus() {
    console.log('BUILD polling: checking status...');
    const statusUrl = '@Url.Action("GetBuildStatus", "TaxReporting")' + '?_=' + Date.now();

    fetch(statusUrl, {
        method: 'GET',
        cache: 'no-store',
        headers: {
            'Accept': 'application/json'
        }
    })
    .then(response => {
        if (!response.ok) {
            throw new Error(`Status polling failed: ${response.status}`);
        }
        return response.json();
    })
    .then(data => {
        buildPollFailureCount = 0;
        console.log('BUILD status response:', data);
        setBuildAssociationScope(data.scopeDisplay);
        setBuildLastUpdateText('Last backend update', data.lastUpdated || data.timestamp);
        if (data.isRunning) {
            const progress = Math.min(Math.max(data.progress || 0, 0), 100);
            const ageSeconds = Number.isFinite(data.ageSeconds) ? data.ageSeconds : 0;

            if (progress === lastBuildProgressValue) {
                buildUnchangedPollCount += 1;
            } else {
                lastBuildProgressValue = progress;
                buildUnchangedPollCount = 0;
            }

            console.log('Build is still running, progress:', progress, 'ageSeconds:', ageSeconds);
            if (!buildPollingInterval) {
                startBuildPolling();
            }
            isBuildRunning = true;
            if (window.localStorage) {
                localStorage.setItem(buildInProgressStorageKey, '1');
            }
            showBuildProgress();
            const isStale = ageSeconds >= buildStaleThresholdSeconds;
            const statusText = (buildUnchangedPollCount >= 5 || isStale)
                ? `Build is still running (${progress}%). Last backend update ${ageSeconds}s ago.`
                : `Building records: ${progress}% complete`;
            updateBuildProgress(progress, statusText);
            return;
        }

        // Clear stale marker/UI when no build is active and no completion payload exists.
        if (!data.result && !data.error) {
            // App restart/cleanup: client still has in-progress marker but server has no build state.
            if (window.localStorage && localStorage.getItem(buildInProgressStorageKey) === '1' && data.hasState === false) {
                localStorage.removeItem(buildInProgressStorageKey);
                stopBuildPolling();
                hideBuildProgress();
                buildUnchangedPollCount = 0;
                lastBuildProgressValue = -1;
                isBuildRunning = false;
                if (!isValidationRunning) {
                    enableMenuOptions();
                }
                showBuildStoppedAlert('Application was restarted or stopped. In-progress build was cleaned up.');
                return;
            }

            // Backend status can be temporarily unavailable while the build worker starts
            // or when cache/session reads lag. Keep showing the waiting UI as long as
            // the client marker indicates a build attempt is in-flight.
            if (window.localStorage && localStorage.getItem(buildInProgressStorageKey) === '1') {
                showBuildProgress();
                updateBuildProgress(Math.max(1, lastBuildProgressValue > 0 ? lastBuildProgressValue : 1),
                    'Build is still in progress... waiting for backend update');
                setBuildLastUpdateText('Waiting for first backend update', new Date());
                return;
            }

            if (window.localStorage) {
                localStorage.removeItem(buildInProgressStorageKey);
            }
            stopBuildPolling();
            hideBuildProgress();
            buildUnchangedPollCount = 0;
            lastBuildProgressValue = -1;
            if (!isValidationRunning) {
                enableMenuOptions();
            }
            isBuildRunning = false;
            return;
        }

        console.log('Build has completed');
        stopBuildPolling();
        hideBuildProgress();
        buildUnchangedPollCount = 0;
        lastBuildProgressValue = -1;
        if (window.localStorage) {
            localStorage.removeItem(buildInProgressStorageKey);
        }

        if (!isValidationRunning) {
            enableMenuOptions();
        }

        if (data.result) {
            setBuildLastUpdateText('Build completed at', data.timestamp);
            renderFormMessage('success', data.result);
        } else if (data.error) {
            setBuildLastUpdateText('Build failed at', data.timestamp);
            renderFormMessage('error', data.error);
        }

        isBuildRunning = false;
    })
    .catch(error => {
        console.error('Error checking build status:', error);
        buildPollFailureCount += 1;
        setBuildLastUpdateText('Last status check failed (retrying)', new Date());

        // After repeated failures, assume app stopped/unavailable and clean stale in-progress marker.
        if (buildPollFailureCount >= buildPollFailureThreshold && window.localStorage && localStorage.getItem(buildInProgressStorageKey) === '1') {
            localStorage.removeItem(buildInProgressStorageKey);
            stopBuildPolling();
            hideBuildProgress();
            buildUnchangedPollCount = 0;
            lastBuildProgressValue = -1;
            isBuildRunning = false;
            if (!isValidationRunning) {
                enableMenuOptions();
            }
            showBuildStoppedAlert('Application is unavailable. In-progress build state was cleared on this screen.');
        }
    });
}
</script>
}
