@model FormMenuViewModel
@{
    ViewData["Title"] = $"Form Menu – {Model.FormName}";
}

<!-- ═══════════════════════════════════════════════════════════════════════
     SF02 – Tax Reporting System Single Form Menu
     Mirrors TX9501FM record format SF02 and the logic in tx9501cl.clp.
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="terminal-panel">

    <!-- ── Row 1 / Row 2 header ─────────────────────────────────────────── -->
    <div class="terminal-header d-flex justify-content-between">
        <span>@DateTime.Now.ToString("MM/dd/yy")</span>
        <span class="fw-bold fs-6">Tax Reporting System - Single Form Menu</span>
        <span>TX9501</span>
    </div>
    <div class="terminal-header d-flex justify-content-between">
        <span>@DateTime.Now.ToString("HH:mm:ss")</span>
        <span class="text-info">
            @Model.FormName &nbsp;-&nbsp; @Model.FormDescription
        </span>
        <span>SF02</span>
    </div>

    <!-- ── Row 4 – Tax Year / Status ────────────────────────────────────── -->
    <div class="terminal-banner d-flex justify-content-between mt-2">
        <span>
            <span class="terminal-label">Tax Year:</span>
            <span class="terminal-value text-warning">@Model.TaxControl.TaxYear</span>
            &nbsp;
            <span class="terminal-value">@Model.TaxControl.TaxDescription</span>
        </span>
        <span>
            <span class="terminal-label">Status:</span>
            <span class="terminal-value text-warning">@Model.TaxControl.TaxStatus</span>
        </span>
    </div>

    <hr class="terminal-rule" />

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger py-2 px-3 font-monospace" style="font-size: 0.95rem; border-left: 4px solid #dc3545;">
            <strong>❌ Error:</strong> @Model.ErrorMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success py-2 px-3 font-monospace" style="font-size: 0.95rem; border-left: 4px solid #28a745;">
            @Model.StatusMessage
        </div>
    }

    <!-- ── Selected Associations Info ───────────────────────────────────── -->
    <div class="alert alert-info py-1 px-3 font-monospace small mb-2" style="background-color: #e7f3ff; border: 1px solid #b3d9ff;">
        <span class="fw-bold">Selected Associations:</span> @Model.SelectedAssociationsDisplay
    </div>

    <!-- ── Row 6 – Column headings ──────────────────────────────────────── -->
    <div class="row terminal-colhdr mt-1 mb-1">
        <div class="col-1"><span class="text-info fw-bold">Opt</span></div>
        <div class="col-11"><span class="text-info fw-bold">Description</span></div>
    </div>

    <form asp-action="FormMenu" method="post" id="formMenuForm">
        @Html.AntiForgeryToken()

        <!-- ── Row 7  – Maintain ────────────────────────────────────────── -->
        @FormRow("MAINTAIN", "opt_maintain", Model.D_Maintain)

        <!-- ── Row 9  – Edit / Validate (Check for Errors) ─────────────────────────────────── -->
        @FormRow("EDIT",     "opt_edit",     "Check for Errors – select associations")

        <!-- ── Row 11 – Print Detail ────────────────────────────────────── -->
        @FormRow("PRTDTL",   "opt_prtdtl",  Model.D_PrtDtl)

        <!-- ── Row 12 – Print Exclusion ─────────────────────────────────── -->
        @FormRow("PRTEXC",   "opt_prtexc",  Model.D_PrtExc)

        <!-- ── Row 13 – Print Errors ────────────────────────────────────── -->
        @FormRow("PRTERR",   "opt_prterr",  Model.D_PrtErr)

        <!-- ── Row 14 – Summary ─────────────────────────────────────────── -->
        @FormRow("SUMMARY",  "opt_summary", Model.D_Summary)

        <!-- ── Row 16 – Clear ───────────────────────────────────────────── -->
        @FormRow("CLEAR",    "opt_clear",   Model.D_Clear)

        <!-- ── Row 17 – Build ───────────────────────────────────────────── -->
        @FormRow("BUILD",    "opt_build",   Model.D_Build)

        @* Row 19 – Letter option (IN81): only shown for 1098 form *@
        @if (Model.ShowLetterOption)
        {
            @FormRow("LETTER", "opt_letter", Model.D_Letter)
        }

        <hr class="terminal-rule" />

        <!-- ── Row 24 – Function keys ────────────────────────────────────── -->
        <div class="d-flex gap-3 mt-2" id="menuButtons">
            <button type="submit" class="btn btn-success btn-sm font-monospace menuButton"
                    onclick="return validateAction();" id="enterBtn">
                Enter
            </button>
            <!-- F12 = Cancel → back to Main Menu -->
            <button type="submit" name="backToMain" value="1"
                    class="btn btn-outline-warning btn-sm font-monospace menuButton" id="cancelBtn">
                F12 = Cancel
            </button>
            <!-- F3 = Exit → clears session -->
            <button type="submit"
                    formaction="@Url.Action("Exit", "TaxReporting")"
                    formmethod="post"
                    class="btn btn-outline-secondary btn-sm font-monospace menuButton" id="exitBtn">
                F3 = Exit
            </button>
        </div>

        <!-- Validation Progress Indicator (hidden until validation runs) -->
        <div id="validationProgress" style="display: none; margin-top: 20px; padding: 20px; background-color: #f8f9fa; border-radius: 5px;">
            <div style="text-align: center; margin-bottom: 15px;">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                    <span class="visually-hidden">Validating...</span>
                </div>
            </div>
            <p class="mt-2 font-monospace text-muted" style="text-align: center; margin-bottom: 15px;">
                <strong>⏳ Validation in progress...</strong><br>
                <small>Please wait while records are being validated.</small>
            </p>
            
            <!-- Progress Bar -->
            <div style="margin-top: 15px;">
                <div class="progress" style="height: 25px;">
                    <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" 
                         role="progressbar" 
                         style="width: 0%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: white; font-size: 12px;">
                        0%
                    </div>
                </div>
                <p class="mt-2 font-monospace text-muted" style="text-align: center; margin: 0; font-size: 0.9rem;">
                    <span id="progressText">Processing records...</span>
                </p>
            </div>
        </div>
    </form>
</div>

@* Helper – renders one option row (radio + label), matching IBM i input-capable fields *@
@functions {
    Microsoft.AspNetCore.Html.IHtmlContent FormRow(string actionValue, string radioId, string description)
    {
        return new Microsoft.AspNetCore.Html.HtmlString($@"
        <div class=""terminal-row row align-items-center py-0"">
            <div class=""col-1"">
                <input type=""radio""
                       class=""form-check-input terminal-opt-radio menuRadio""
                       name=""action""
                       value=""{actionValue}""
                       id=""{radioId}"" />
            </div>
            <div class=""col-11 font-monospace"">
                <label for=""{radioId}"" class=""mb-0 w-100"" style=""cursor:pointer;"">
                    {description}
                </label>
            </div>
        </div>");
    }
}

@section Scripts {
<script>
// Track validation polling state
let validationPollingInterval = null;
let isValidationRunning = @(Model.IsValidationRunning ? "true" : "false");

document.addEventListener('DOMContentLoaded', function() {
    // If validation was already running when page loaded, start polling
    if (isValidationRunning) {
        disableMenuOptions();
        showValidationProgress();
        startValidationPolling();
    }
});

function validateAction() {
    const selected = document.querySelector('input[name="action"]:checked');
    if (!selected) {
        alert('Please select an option.');
        return false;
    }
    
    // If user selects EDIT (validation), disable options immediately
    if (selected.value === 'EDIT') {
        console.log('Validation selected - will disable options after redirect');
    }
    
    console.log('Form option selected:', selected.value);
    return true;
}

function disableMenuOptions() {
    // Disable all menu radio buttons
    document.querySelectorAll('.menuRadio').forEach(radio => {
        radio.disabled = true;
    });
    
    // Disable all menu buttons
    document.querySelectorAll('.menuButton').forEach(btn => {
        btn.disabled = true;
        btn.style.opacity = '0.5';
        btn.style.cursor = 'not-allowed';
    });
}

function enableMenuOptions() {
    // Enable all menu radio buttons
    document.querySelectorAll('.menuRadio').forEach(radio => {
        radio.disabled = false;
    });
    
    // Enable all menu buttons
    document.querySelectorAll('.menuButton').forEach(btn => {
        btn.disabled = false;
        btn.style.opacity = '1';
        btn.style.cursor = 'pointer';
    });
}

function showValidationProgress() {
    const progressDiv = document.getElementById('validationProgress');
    if (progressDiv) {
        progressDiv.style.display = 'block';
    }
}

function hideValidationProgress() {
    const progressDiv = document.getElementById('validationProgress');
    if (progressDiv) {
        progressDiv.style.display = 'none';
    }
}

function startValidationPolling() {
    // Poll status every 1 second
    validationPollingInterval = setInterval(checkValidationStatus, 1000);
}

function stopValidationPolling() {
    if (validationPollingInterval) {
        clearInterval(validationPollingInterval);
        validationPollingInterval = null;
    }
}

function checkValidationStatus() {
    fetch('@Url.Action("GetValidationStatus", "TaxReporting")', {
        method: 'GET',
        headers: {
            'Accept': 'application/json'
        }
    })
    .then(response => response.json())
    .then(data => {
        console.log('Validation status:', data);
        
        // Update progress bar if validation is running
        if (data.isRunning) {
            const progressBar = document.getElementById('progressBar');
            const progressText = document.getElementById('progressText');
            
            if (progressBar) {
                const progress = Math.min(Math.max(data.progress || 0, 0), 100);
                progressBar.style.width = progress + '%';
                progressBar.textContent = progress + '%';
            }
            
            if (progressText) {
                const progress = data.progress || 0;
                progressText.textContent = `Processing records: ${progress}% complete`;
            }
        } else {
            // Validation has completed
            stopValidationPolling();
            hideValidationProgress();
            enableMenuOptions();
            
            // Set progress to 100% before hiding
            const progressBar = document.getElementById('progressBar');
            if (progressBar) {
                progressBar.style.width = '100%';
                progressBar.textContent = '100%';
            }
            
            // Show completion message
            if (data.result) {
                const successAlert = document.createElement('div');
                successAlert.className = 'alert alert-success alert-dismissible fade show py-2 px-3 font-monospace';
                successAlert.style.fontSize = '0.95rem';
                successAlert.style.borderLeft = '4px solid #28a745';
                successAlert.innerHTML = data.result + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
                
                const formMenu = document.querySelector('.terminal-panel');
                const firstChild = formMenu.querySelector('.alert, .terminal-header');
                if (firstChild) {
                    firstChild.parentNode.insertBefore(successAlert, firstChild);
                } else {
                    formMenu.insertBefore(successAlert, formMenu.firstChild);
                }
            } else if (data.error) {
                const errorAlert = document.createElement('div');
                errorAlert.className = 'alert alert-danger alert-dismissible fade show py-2 px-3 font-monospace';
                errorAlert.style.fontSize = '0.95rem';
                errorAlert.style.borderLeft = '4px solid #dc3545';
                errorAlert.innerHTML = '<strong>❌ Error:</strong> ' + data.error + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
                
                const formMenu = document.querySelector('.terminal-panel');
                const firstChild = formMenu.querySelector('.alert, .terminal-header');
                if (firstChild) {
                    firstChild.parentNode.insertBefore(errorAlert, firstChild);
                } else {
                    formMenu.insertBefore(errorAlert, formMenu.firstChild);
                }
            }
            
            isValidationRunning = false;
        }
    })
    .catch(error => {
        console.error('Error checking validation status:', error);
        // Continue polling on error
    });
}
</script>
}
