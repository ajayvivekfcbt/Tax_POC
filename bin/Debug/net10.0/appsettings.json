{
  "ConnectionStrings": {
    /*
     * IBM i Access ODBC connection string.
     * Replace MY_IBMI_HOST, MY_USER, MY_PASSWORD, and MY_TXLIB
     * with your actual IBM i system values.
     *
     * Prerequisites:
     *   - IBM i Access Client Solutions installed on the web server
     *   - ODBC Driver: "IBM i Access ODBC Driver"
     *
     * DefaultLibraries specifies the IBM i library that contains
     * the TXRCTL, TXRDTL, and other tax reporting physical files.
     */
    "IBMi": "Driver={IBM i Access ODBC Driver};System=dev;UID=u4142ap;PWD=bluefish6;DefaultLibraries=datcomn;CommitMode=0;Naming=1",
    /*
     * SQLite local staging database.
     * Records created via the web UI are stored here before they are
     * synced to IBM i.  The file is created automatically on first run.
     */
    "SQLite": "Data Source=tax_reporting_local.db"
  },
  "IBMiSettings": {
    /*
     * Library (schema) on IBM i that contains the tax reporting files
     * and programs (TXRCTL, TXRDTL, TX9505, TX9510, etc.)
     */
    "Library": "DATCOMN"
  },
  "Server": {
    "Urls": "http://localhost:5000",
    "UseHttpsRedirection": false
  },
  "Diagnostics": {
    "EnableEfSensitiveDataLogging": false,
    "LogNullOrEmptyKeyFields": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Tx9501": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1"
}
