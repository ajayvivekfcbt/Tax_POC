<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Tx9501</RootNamespace>
    <AssemblyName>Tax_POC_App</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <!--
      System.Data.Odbc – required to connect to IBM i DB2 via the
      IBM i Access ODBC Driver (Windows).
      Install IBM i Access Client Solutions from:
      https://www.ibm.com/support/pages/ibm-i-access-client-solutions
    -->
    <PackageReference Include="System.Data.Odbc" Version="10.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="9.0.4" />
    <PackageReference Include="QuestPDF" Version="2024.10.3" />
    <!--
      Microsoft.AspNetCore.Session and Microsoft.Extensions.Caching.Memory
      are included in the ASP.NET Core shared framework for .NET 6+;
      no explicit package reference is needed.
    -->
  </ItemGroup>

</Project>
